cd /home/net/al663069/SD2_ws/scaler_asic_design/modifiedCoreTesting/rtl_test
mkdir -p xrun_netlist_test
summary=xrun_netlist_test/regression_summary.txt
: > "$summary"
for vmem in tests/compiled/*.vmem; do
  name=$(basename "$vmem" .vmem)
  log="xrun_netlist_test/${name}.run.log"
  echo "===== $name =====" | tee -a "$summary"
  if VMEM="$PWD/$vmem" bash ./run_netlist_test.sh > "$log" 2>&1; then
    status=0
  else
    status=$?
  fi
  sw=$(awk '/=== Software output/{flag=1; next} flag{print}' "$log")
  if [[ -z "$sw" ]]; then
    verdict="NO_OUTPUT"
  elif grep -q "PASS:" <<< "$sw"; then
    verdict="PASS"
  elif grep -q "FAIL:" <<< "$sw"; th    verdict="FAIL"
