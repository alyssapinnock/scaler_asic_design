# Set design file paths and parameters
set netlist_directory   "../Synthesis/outputs/"
set lef_directory       "../lef/"
set qrc_directory       "../QRC_Tech/"
set mmmc_directory      "./"

set_db init_netlist_files   $netlist_directory
set_db init_mmmc_files      $mmmc_directory

set_db init_power_nets VDD
set_db init_ground_nets VSS

# Load MMC configuration
read_mmmc masked_core.view

# Read LEF files
read_physical -lefs [list \
    [file join $lef_directory "gsclib045_tech.lef"] \
    [file join $lef_directory "gsclib045_macro.lef"]]

read_netlist [file join $netlist_directory "top_netlist.v"]


set ASPECT_RATIO        1.0;
set TARGET_DENSITY      0.6;
set STD_CELL_AREA       190154.394;
set IO_MARGIN           100.0;
set SITE_NAME           "CoreSite"

set core_area [expr {$STD_CELL_AREA / $TARGET_DENSITY}]
set core_width  [expr {sqrt($core_area / $ASPECT_RATIO)}]
set core_height [expr {$ASPECT_RATIO * $core_width}]
 
# Round up to nearest site width/height to avoid legalization issues
# GPDK045 site: 0.38 µm wide, 0.28 µm tall — change if using different PDK
set SITE_WIDTH  0.2
set SITE_HEIGHT 1.71
 
set core_width  [expr {ceil($core_width  / $SITE_WIDTH)  * $SITE_WIDTH}]
set core_height [expr {ceil($core_height / $SITE_HEIGHT) * $SITE_HEIGHT}]

set die_width  [expr {$core_width  + 2 * $IO_MARGIN}]
set die_height [expr {$core_height + 2 * $IO_MARGIN}]
init_design
create_floorplan \
    -site        $SITE_NAME \
    -core_size   $core_width $core_height \
                 $IO_MARGIN $IO_MARGIN $IO_MARGIN $IO_MARGIN

connect_global_net VDD -type pg_pin -pin VDD -inst *
connect_global_net VSS -type pg_pin -pin VSS -inst *
# connect_global_net VDD -type tie_hi
# connect_global_net VSS -type tie_lo
# connect_global_net VDD -type tie_hi -pin VDD -inst *
# connect_global_net VSS -type tie_lo -pin VSS -inst *


